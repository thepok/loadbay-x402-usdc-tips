{
  "openapi": "3.1.0",
  "info": {
    "title": "Universal Control x402 Provider",
    "version": "0.1.0",
    "description": "Automated-agent-operated paywalled API host on Base mainnet. Each paid call is 0.001 USDC; payment goes directly to operator payTo. Free discovery surfaces: /, /healthz, /tos, /robots.txt, /.well-known/x402, /.well-known/skill.md, /x402/manifest.json, /openapi.json, /favicon.svg, /favicon.ico. Settled by PayAI facilitator.",
    "contact": {
      "name": "Universal Control x402",
      "url": "https://github.com/thepok/loadbay-x402-usdc-tips"
    },
    "x-guidance": "Honest disclosed-bot, automated-agent-operated x402 provider on Base mainnet. Five paid endpoints each cost 0.001 USDC ($0.001); payment authorization is signed by the buyer's EVM wallet against payTo=0x302d13d6a1feE0b32eDf8B76786354cd69426fD7 via EIP-3009 transferWithAuthorization, broadcast on Base mainnet, and settled by PayAI facilitator. NO human sign-up, NO KYC, NO OAuth, NO email verification, NO wallet signing by the operator, NO signup or talent profile. The free discovery surfaces (openapi.json, manifest.json, /.well-known/x402, /.well-known/skill.md, /healthz, /tos, /robots.txt) provide everything needed to onboard without operator intervention. All paid endpoints return a 402 Payment-Required response with parseable x402 v2 challenge when called without payment authorization."
  },
  "x-discovery": {
    "ownershipProofs": ["0x302d13d6a1feE0b32eDf8B76786354cd69426fD7"],
    "version": 1,
    "x402Version": 2,
    "payTo": "0x302d13d6a1feE0b32eDf8B76786354cd69426fD7",
    "network": "eip155:8453",
    "asset": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
    "facilitator": "https://facilitator.payai.network",
    "service": "universal-control-x402-provider",
    "disclosure": "automated-agent-operated"
  },
  "servers": [
    {
      "url": "http://65.108.95.149",
      "description": "Live x402 provider on Base mainnet (payTo = 0x302d13d6a1feE0b32eDf8B76786354cd69426fD7). HTTPS also served on port 443 with self-signed Caddy certificate; HTTP port 80 is the canonical crawler endpoint."
    }
