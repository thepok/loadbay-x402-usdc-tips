  "paths": {
    "/x402/health": {
      "get": {
        "summary": "Health probe — returns provider liveness + Base block head",
        "description": "Returns a JSON object with provider status, started_at, uptime_seconds, and the latest Base block number / finalised state. Pay $0.001 USDC per call (atomic 1000).",
        "operationId": "getX402Health",
        "security": [{"x402-payment": []}],
        "responses": {
          "200": {
            "description": "Successful paid health probe",
            "content": { "application/json": { "schema": { "type": "object" } } }
          },
          "402": {
            "description": "Payment required (x402 v2 challenge with accepts[])",
            "headers": {
              "Payment-Required": {
                "schema": { "type": "string" },
                "description": "x402 v2 payment-required header"
              }
            },
            "content": { "application/json": { "schema": { "type": "object" } } }
          }
        },
        "x-payment-info": {
          "protocols": [{"x402": {}}],
          "price": { "mode": "fixed", "currency": "USD", "amount": "0.001" },
          "payTo": "0x302d13d6a1feE0b32eDf8B76786354cd69426fD7",
          "network": "eip155:8453",
          "asset": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
          "facilitator": "https://facilitator.payai.network"
        }
      }
    },
